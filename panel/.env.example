# Copy this file to ".env" and fill in your values.

# Required: your Apify API token — starts with "apify_api_..."
# Get it at https://console.apify.com/account/integrations
APIFY_TOKEN=

# Optional: the Actor id to run (defaults to the published one)
APIFY_ACTOR_ID=vZaPYHqFzqndnJ2Cw

# Optional: default Groq API key (gsk_...) used when the AI analysis is ON and you
# leave the key field blank in the panel. You can also type the key in the panel.
GROQ_API_KEY=

# Optional: port for the local panel (default 3000)
PORT=3000
